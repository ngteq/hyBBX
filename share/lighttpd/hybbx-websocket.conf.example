# HyBBX WebSocket — lighttpd 1.4 (mod_proxy). Install: ~/hybbx/  path /hybbx :4591

$HTTP["url"] =~ "^/hybbx-telnet" {
    proxy.server = ( "" => (
        "hybbx" => (
            "proxy"  => "https://127.0.0.1:4591/hybbx",
            "upgrade" => "enable"
        )
    ))
    proxy.header = ( "upgrade" => "enable" )
}

# Plain ws: "proxy" => "http://127.0.0.1:4591/hybbx"
