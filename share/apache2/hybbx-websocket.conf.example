# HyBBX WebSocket — Apache 2.4 inside your HTTPS VirtualHost.
# Install: ~/hybbx/  —  127.0.0.1:4591 path /hybbx  —  keys/hybbx_ws.*

<IfModule mod_proxy.c>
    ProxyPreserveHost On
    SSLProxyEngine On
    SSLProxyVerify none

    # Public /hybbx-telnet → backend /hybbx (wss + self-signed loopback cert)
    ProxyPass "/hybbx-telnet" "wss://127.0.0.1:4591/hybbx"
    ProxyPassReverse "/hybbx-telnet" "wss://127.0.0.1:4591/hybbx"
</IfModule>
