; HyBBX Secondary — v2.0.0. Full keys: docs/MANUAL.md
; Remote RF edge → Main [circuit]. Not a telnet user on Main.

[service]
name = hyBBX-secondary

[storage]
backend = flatfile
path = data-secondary

[auth]
auto_login = no

[traffic]
baud = 2400
line_width = 80
pace_output = yes
ansi = no
input_echo = no

[mail]
enabled = no

[networks]
ax25 = yes
ardop = no
crdop = no
circuit = no

[transport.telnet]
bind = 127.0.0.1
bind6 = ::1
port = 2323
ipv4 = yes
ipv6 = yes

; Section name must match Main [transport.packet_radioN]
[transport.packet_radio1]
circuit_host = main.example.com
circuit_port = 7323
link_id = secondary-1
link_password = changeme
link_role = link
frequency_mhz = 27.205
tnc = tnc2c
protocol = kiss
device_type = usb
device = /dev/ttyUSB0
baud = 2400
serial_line = 7e1
modem = tcm3105
radio_baud = 1200
clock_mhz = 4.9
kiss_on_startup = yes
txdelay = 50
persist = 128
slot = 10
txtail = 0
radio_band = amateur
radio_duplex = half
g3ruh_fsk = no

[ax25]
frequency1 = 27.205
frequency2 = 27.215

; ARDOP: docs/ARDOP.md — start external ARDOPC first
; CRDOP: docs/CRDOP.md — start external CRDOPC first (github.com/ngteq/CRDOP)
