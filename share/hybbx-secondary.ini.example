; HyBBX Secondary — v1.1.0. Full keys: docs/MANUAL.md
; Remote RF edge → Main [circuit]. Not a telnet user on Main.

[service]
name = hyBBX-secondary

[storage]
backend = flatfile
path = data-secondary

[auth]
auto_login = no

[traffic]
baud = 2400
line_width = 80
pace_output = yes
ansi = no
input_echo = no

[mail]
enabled = no

[networks]
ax25 = yes
baycom = no
ardop = no
crdop = no
circuit = no

[transport.telnet]
bind = 127.0.0.1
bind6 = ::1
port = 2323
ipv4 = yes
ipv6 = yes

; Section name must match Main [transport.packet_radioN]
[transport.packet_radio1]
circuit_host = main.example.com
circuit_port = 7323
link_id = secondary-1
link_password = changeme
link_role = link
frequency_mhz = 27.205
tnc = tnc2c
protocol = kiss
device_type = usb
device = /dev/ttyUSB0
baud = 2400
serial_line = 7e1
kiss_entry = kiss_on
modem = tcm3105
radio_baud = 1200
clock_mhz = 4.9
txdelay = 50
persist = 128
slot = 10
txtail = 0
radio_band = amateur
radio_duplex = half
g3ruh_fsk = no

; Second TNC on same Secondary (unique device + link_id; Main needs matching section):
; [transport.packet_radio2]
; tnc = tnc2
; protocol = kiss
; device_type = serial
; device = /dev/ttyUSB1
; baud = 9600
; serial_line = 8n1
; kiss_entry = auto
; circuit_host = main.example.com
; link_id = secondary-2
; link_password = changeme2

; BayCom PR-Stack (kernel SER12) — see docs/BAYCOM.md
; [networks]
; baycom = yes
; ax25 = no
;
; [transport.baycom1]
; backend = kernel
; mode = ser12*
; interface = bcsf0
; iobase = 0x3f8
; irq = 4
; radio_baud = 1200
; circuit_host = main.example.com
; circuit_port = 7323
; link_id = baycom-1
; link_password = changeme

[ax25]
frequency1 = 27.205
frequency2 = 27.215

; ARDOP: docs/ARDOP.md — start external ARDOPC first
; CRDOP: docs/CRDOP.md — start external CRDOPC first (github.com/ngteq/CRDOP)
