; HyBBX Secondary — RF/TNC and other link adapters; bridges to Main over TCP/IP
;
; Default role: run AX.25 and hardware adapters here; Main stays TCP/IP + HBX only.
; One Secondary per RF site (or more); each registers on Main as [transport.<plugin>N].
;
;   cp share/hybbx-secondary.ini.example ~/.hybbx-secondary.ini
;   hybbx -c ~/.hybbx-secondary.ini
;
; Main template (datacenter defaults): share/hybbx.ini.example
;   [networks] ax25=no circuit=yes  — telnet + HBX hub only on Main
;   [circuit] bind = 0.0.0.0  +  link_password
;   [transport.packet_radio1]  link_id + link_password (same section name here)
;
; HyBBX auth: link_id and link_password only (on Main bridge section and here).
; Advanced security: system firewall, system VPN, SSH tunnels, stunnel, etc.
; HyBBX does not integrate those — point circuit_host at the reachable Main address.

[service]
name = hyBBX-secondary

[storage]
backend = flatfile
path = ~/.hybbx-secondary

[auth]
; Login prompt: registered /login and /register only (no guest auto-login).
auto_login = no

[traffic]
baud = 2400
line_width = 80
pace_output = yes
ansi = no
input_echo = yes

[mail]
enabled = no

[networks]
; Secondary defaults: AX.25 on, HBX circuit hub off (client to Main only).
ax25 = yes
circuit = no

[transport.telnet]
; Local maintenance only
bind = 127.0.0.1
bind6 = ::1
port = 2323
ipv4 = yes
ipv6 = yes

; Section name must match Main [transport.packet_radio1] (increment N per Secondary).
[transport.packet_radio1]
; TCP/IP bridge to Main (HBX v1 on [circuit])
circuit_host = main.example.com
circuit_port = 7323
link_id = secondary-1
link_password = changeme
link_role = link

; --- TNC2C (primary test device) ---
tnc = tnc2c
protocol = kiss
device_type = usb
device = /dev/ttyUSB0
baud = 2400
modem = tcm3105
radio_baud = 1200
clock_mhz = 4.9
kiss_on_startup = yes
txdelay = 50
persist = 128
slot = 10
txtail = 0
radio_band = amateur
radio_duplex = half
g3ruh_fsk = no

; AX.25 (set before on-air use)
; mycall = DL1ABC-0
; dest = DL9XYZ-0
; via = RELAY-7
