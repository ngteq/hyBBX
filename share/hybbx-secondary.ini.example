; HyBBX v2.0.0 — Secondary (RF edge → Main HBX hub)
; Pair with: share/hybbx-main.ini.example or share/hybbx-mesh.ini.example
; link_id / link_password / frequency_mhz must match Main [transport.packet_radioN]

[service]
name = hyBBX-secondary

[storage]
backend = flatfile
path = data-secondary

[auth]
auto_login = no

[log]
enabled = yes
dir = logs
level = warn

[networks]
ax25 = yes
circuit = no

[transport.packet_radio1]
circuit_host = main.example.com
circuit_port = 7323
link_id = secondary-1
link_password = changeme
frequency_mhz = 27.205
tnc = tnc2c
protocol = kiss
device = /dev/ttyUSB0
baud = 9600
kiss_entry = kiss_on
modem = tcm3105
radio_baud = 1200
radio_band = amateur
radio_duplex = half

[ax25]
frequency1 = 27.205
