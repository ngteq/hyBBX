# HyBBX — lighttpd 1.4 (mod_proxy + mod_fastcgi). HYBBX_ROOT=/home/hybbx/hybbx

$HTTP["url"] == "/hybbx-websocket/ws" {
    proxy.server = ( "" => (
        "hybbx" => (
            "proxy"   => "https://127.0.0.1:4591/hybbx",
            "upgrade" => "enable"
        )
    ))
    proxy.header = ( "upgrade" => "enable" )
}

alias.url += ( "/hybbx-websocket/" => "/home/hybbx/hybbx/hybbx-websocket/" )
index-file.names += ( "index.php" )

fastcgi.server += ( ".php" =>
    ( "localhost" =>
        ( "socket" => "/var/run/php-fpm.sock" )
    )
)

# Plain ws: "proxy" => "http://127.0.0.1:4591/hybbx"
