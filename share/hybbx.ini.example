; HyBBX Main instance configuration — version target: 0.6.0
; Default profile: datacenter Main — TCP/IP on this host only.
;
;   ON by default:  telnet (user sessions), HBX circuit hub on loopback (Secondaries via bind change)
;   OFF by default: ax25, websocket — run on Secondary instance(s) instead
;
; AX.25 and other non-core adapters normally live on one or more Secondaries that
; bridge RF/TNC traffic to this Main over HBX/TCP. The INI is fully overrideable:
; set ax25=yes and add [transport.packet_radio] here to run all connection types
; locally on Main without remote HBX (single-box, lab, or legacy site).
;
; Release scope docs (RELEASE-*) begin at v1.0.0 — see docs/ROADMAP.md
; Arch: docs/ROADMAP.md  |  API: include/hybbx/*.h  |  Install: <prefix>/hybbx/hybbx.ini
;
; Sections:
;   [service]            daemon name, max_online, prompt
;   [time]               system-local timestamps (yyyymmdd, 24h default)
;   [log]                optional file logging (disabled by default)
;   [storage]            flatfile path (sql planned)
;   [auth]               guests, registration
;   [crypto]             backends (bundled default; optional OpenSSL/libsodium via CMake)
;   [traffic]            baud/line_width pacing (default 2400/80)
;   [texts]              banner, motd, news
;   [chat]               channels
;   [mail]               personal mailbox (Main only)
;   [networks]           connection switches (ax25, websocket, circuit)
;   [transport.telnet]   TCP telnet adapter (port 2323) — static enabled
;   [circuit]            HBX TCP hub — secondaries connect here (main instance)
;   [transport.packet_radioN]  Bridge registry on Main (one section per Secondary)
;                              Secondary: same section name + TNC/RF settings
;
; Templates:
;   share/hybbx.ini.example           — Main
;   share/hybbx-secondary.ini.example — Secondary (TNC/modem, no local mail)
;
; Booleans: yes/no (aliases true/false, on/off, 1/0). Storage path supports ~ for $HOME.

[service]
name = hyBBX
; max_online = 35        ; maximum simultaneous sessions (guests included)
; nodes = 35               ; alias for max_online
; prompt =              ; default: empty (no visible prompt before input)
; prompt = hybbx>

; HyBBX timestamps use system local time: yyyymmdd + 24-hour HH:MM (no seconds).
[time]
; clock = 24h            ; 24h (default) | 12h | am_pm
; clock_12h = no         ; alias: yes enables 12-hour am/pm display
; am_pm = no             ; alias for clock_12h
; seconds = no           ; append :SS when yes

; File logging — disabled unless enabled=yes and dir is set.
; New log file on the first day of each calendar month: yyyymmdd-hybbx.log
; [log]
; enabled = no
; dir = logs             ; relative to install root (HYBBX_ROOT); default when enabled
; level = info           ; debug | info | stats | warn

[storage]
backend = flatfile
; Flat-file data root (relative to install prefix when started via hybbx-start):
path = data
; User accounts: <path>/users/users.ini (default Sysop created on first start)
; Per-user mail: <path>/mail/<user>/inbox/

[auth]
auto_login = yes
guest_prefix = Guest
; guest_timeout_minutes = 30   ; auto-disconnect guests after this many minutes
; auto_login=no: login prompt for registered /login and /register (no guest slots)

; System-wide cryptography (bundled sources are defaults; no external libs required).
; Optional OpenSSL/libsodium backends: cmake -DHYBBX_CRYPTO_OPENSSL=ON / -DHYBBX_CRYPTO_LIBSODIUM=ON
[crypto]
password_hash = tinysha256    ; tinysha256 | openssl
aes_gcm = tinyaes             ; tinyaes | openssl
chacha = monocypher           ; monocypher | libsodium
x25519 = monocypher           ; monocypher | libsodium
random = system               ; system | openssl

; 2400 baud traffic profile (80 columns, paced 8N1 output, plain ASCII).
[traffic]
baud = 2400
line_width = 80
pace_output = yes
ansi = no
input_echo = yes

[texts]
path = text

[chat]
channels = 10
message_max = 72
; Default names: Channel1 … Channel10 (override per channel):
channel1 = Channel1
channel2 = Channel2
channel3 = Channel3
channel4 = Channel4
channel5 = Channel5
channel6 = Channel6
channel7 = Channel7
channel8 = Channel8
channel9 = Channel9
channel10 = Channel10

[mail]
enabled = yes
max_messages = 50
subject_max = 72
body_max = 2048
recycle_days = 10
path = mail

; Connection switches — datacenter Main defaults below.
; Telnet and SSH are static-enabled core IP transports (always on when built).
; Optional adapters (ax25, websocket) are off here; enable them on Secondary INI
; or override on Main for standalone operation (all types local, no remote HBX).
[networks]
ax25 = no
websocket = no
circuit = yes

[transport.telnet]
; Static-enabled (always started when built). Port/bind only:
bind = 0.0.0.0
bind6 = ::
port = 2323
ipv4 = yes
ipv6 = yes

; Planned later (not implemented):
; [transport.ssh]
; Static-enabled when built (port/bind only, like telnet).
;
; WebSocket: forward-proxy only — place Apache/nginx/httpd in front as reverse-proxy.
; HyBBX accepts proxied upgrades locally; TLS and public HTTP stay on the web server.
; [transport.websocket]
; bind = 127.0.0.1
; port = 8080
; upstream = reverse-proxy   ; informational; real TLS/HTTP termination on Apache/nginx

; HBX circuit hub — Main only. Default: loopback (127.0.0.1 / ::1) for security.
; Remote Secondaries: set bind = 0.0.0.0 and bind6 = :: (or a VPN/firewall address).
; HyBBX auth: link_id + link_password only. Firewall/VPN/tunnels: system-level.
; Master switch: [networks] circuit = yes|no
[circuit]
enabled = yes
bind = 127.0.0.1
bind6 = ::1
port = 7323
ipv4 = yes
ipv6 = yes
; Secondary password auth only — no TCP ping/pong health checks.
link_auth = yes
link_password = changeme
link_stale_days = 10

; Bridge registry — one [transport.<plugin>N] section per Secondary on Main.
; HyBBX ships only link_id and link_password here (same keys on the Secondary).
; Section name must match the Secondary INI (e.g. packet_radio1 on both sides).
; Multi-link hub reads these when implemented; today LINK_AUTH uses [circuit] password.
[transport.packet_radio1]
link_id = secondary-1
link_password = changeme
link_role = link

; Second Secondary (comment out until needed):
; [transport.packet_radio2]
; link_id = secondary-2
; link_password = changeme2
; link_role = link

; Full TNC/RF tuning lives on the Secondary only — see hybbx-secondary.ini.example.
; Dev/local single-box test with ax25=yes may use [transport.packet_radio] (unnumbered).
