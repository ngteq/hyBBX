; HyBBX Main — v2.0.0. Full keys: docs/MANUAL.md
; Template: Main datacenter (telnet + HBX hub). RF on Secondary unless standalone.

[service]
name = hyBBX

[time]
clock = 24h
seconds = yes
; date = iso | iso_short | us | eu

[storage]
; flatfile = default, no host packages. sqlite = opt-in (libsqlite3 at build time).
backend = flatfile
path = data
; user_db = users.db
; mail_db = mail.db
; backup_interval = 300
; backup_path =

[auth]
auto_login = yes
guest_prefix = Guest

[crypto]
; Built-in defaults need no host packages.
; OpenSSL (build with -DHYBBX_CRYPTO_OPENSSL=ON, libssl-dev):
;   password_hash = openssl
;   aes_gcm = openssl
;   random = openssl
password_hash = tinysha256
aes_gcm = tinyaes
chacha = monocypher
x25519 = monocypher
random = system

[traffic]
baud = 2400
line_width = 80
pace_output = yes
ansi = no
input_echo = no

[texts]
path = text

[log]
enabled = yes
level = warn

[security]
; Network + abuse (see docs/SECURITY.md). Normal chat/mail limits are in [chat]/[mail] — no bans.
enabled = yes
maxretry = 5
findtime = 600
bantime = 600
abuse_maxretry = 30
abuse_findtime = 600
; ban_callid = SPAM-1, FOOL
telnet = yes
ssh = yes
websocket = yes
circuit = yes
rate_limit = 30
rate_window = 60
ban_backend = internal

[chat]
channels = 10
message_max = 72
channel1 = Channel1
channel2 = Channel2
channel3 = Channel3
channel4 = Channel4
channel5 = Channel5
channel6 = Channel6
channel7 = Channel7
channel8 = Channel8
channel9 = Channel9
channel10 = Channel10

[mail]
enabled = yes
max_messages = 50
subject_max = 72
body_max = 2048
recycle_days = 10
path = mail

[networks]
ax25 = no
baycom = no
ardop = no
crdop = no
ssh = yes
websocket = no
circuit = yes
mains_proxy = no

[transport.telnet]
bind = 0.0.0.0
bind6 = ::
port = 2323
ipv4 = yes
ipv6 = yes

[transport.ssh]
enabled = yes
bind = 0.0.0.0
bind6 = ::
port = 3232
ipv4 = yes
ipv6 = yes
hostkey_dir = keys

[transport.websocket]
enabled = yes
bind = 127.0.0.1
bind6 = ::1
port = 4591
path = /hybbx
cert_dir = keys
max_connections = 10
ipv4 = yes
ipv6 = yes

[circuit]
enabled = yes
bind = 127.0.0.1
bind6 = ::1
port = 7323
ipv4 = yes
ipv6 = yes
link_auth = yes
link_password = changeme
link_stale_days = 10
max_links = 8
balance = yes
balance_lag_sec = 8
balance_queue_pause = 8192
balance_queue_break = 32768
balance_queue_cancel = 131072

[broadcast]
enabled = yes
ax25 = yes
ax25_auto = yes
ax25_auto_interval = 300
; Seconds between successive link phases (0 = all links at once). Dual-radio: 150.
ax25_auto_stagger = 0
ax25_auto_message = Broadcast: @service@ online
ax25_mycall = HYBBX
ax25_dest = QST

[ax25]
frequency1 = 27.205
frequency1_label = local-A
frequency2 = 27.215

; Bridge registry — remote Secondary (link_id only; no device/tnc here).
; For a local TNC on Main, add tnc=, device=, protocol= to the same section shape.
[transport.packet_radio1]
link_id = secondary-1
link_password = changeme
link_role = link
frequency_mhz = 27.205

[transport.packet_radio2]
link_id = secondary-2
link_password = changeme2
link_role = link
frequency_mhz = 27.205

; Optional digital bridges (external modem on Secondary):
; [transport.ardop1]  — docs/ARDOP.md
; [transport.crdop1]  — docs/CRDOP.md

; Proxy network (opt-in; partial — docs/MAINS_PROXY.md):
; [transport.mains_proxy1]
; peer_id = main-peer
; circuit_host = 192.0.2.10
; circuit_port = 7323
; link_id = main-peer
; link_password = changeme
; wire = circuit
; duplex = full
; use_secondary = yes
