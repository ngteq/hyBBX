; HyBBX configuration (installed: etc/hybbx.ini under install prefix).
; Paths below are relative to the install prefix when started via hybbx-start.
;
; Boolean keys: canonical yes/no; aliases true/false, enable/disable, on/off, 1/0.

[service]
name = hyBBX
; max_online = 35        ; maximum simultaneous sessions (guests included)
; nodes = 35               ; alias for max_online
; prompt =              ; default: empty (no visible prompt before input)
; prompt = hybbx>

[storage]
backend = flatfile
path = ./data

[auth]
auto_login = yes
guest_prefix = Guest
; guest_timeout_minutes = 30   ; auto-disconnect guests after this many minutes

; System-wide cryptography (bundled sources are defaults; no external libs required).
; Optional OpenSSL/libsodium backends: cmake -DHYBBX_CRYPTO_OPENSSL=ON / -DHYBBX_CRYPTO_LIBSODIUM=ON
[crypto]
password_hash = tinysha256    ; tinysha256 | openssl
aes_gcm = tinyaes             ; tinyaes | openssl
chacha = monocypher           ; monocypher | libsodium
x25519 = monocypher           ; monocypher | libsodium
random = system               ; system | openssl

; 2400 baud traffic profile (40 columns, paced 8N1 output, plain ASCII).
[traffic]
baud = 2400
line_width = 40
pace_output = yes
ansi = no

[texts]
path = ./text

[chat]
; channels = 10
message_max = 72
; channel1 = General
; channel2 = BBS
; channel3 = Tech
; channel4 = Channel4
; channel5 = Channel5
; channel6 = Channel6
; channel7 = Channel7
; channel8 = Channel8
; channel9 = Channel9
; channel10 = Channel10

[transport.telnet]
enabled = yes
bind = 0.0.0.0
bind6 = ::
port = 2323
; ipv4 = yes
; ipv6 = yes

; Planned later (not implemented):
; [transport.ssh]
; enabled = no
;
; WebSocket: forward-proxy only — place Apache/nginx/httpd in front as reverse-proxy.
; HyBBX accepts proxied upgrades locally; TLS and public HTTP stay on the web server.
; [transport.websocket]
; enabled = no
; bind = 127.0.0.1
; port = 8080
; upstream = reverse-proxy   ; informational; real TLS/HTTP termination on Apache/nginx

; Internal TCP/IPv4+IPv6 circuit hub (HBX framing). Link adapters attach here.
[circuit]
enabled = yes
bind = 127.0.0.1
bind6 = ::1
port = 7323
ipv4 = yes
ipv6 = yes
; Edge links/repeaters: password auth only — no TCP ping/pong health checks.
link_auth = yes
link_password = changeme
link_stale_days = 10

[transport.packet_radio]
enabled = no

; Link adapter → internal circuit (HBX over TCP)
circuit_host = 127.0.0.1
circuit_port = 7323
link_id = packet-radio-1
link_password = changeme
link_role = link

; --- TNC profiles: tnc2c | baycom | pccom | generic ---
; --- Protocols: kiss | hostmode | 6pack ---
tnc = tnc2c
protocol = kiss

; Host serial (2400 baud is the HyBBX default for packet links)
device_type = usb
device = /dev/ttyUSB0
; Windows: device = COM3
; AmigaOS: device = serial.device   (or serial.device:1, or 0 for unit 0)
baud = 2400

; AX.25 addresses (optional; required for over-the-air UI frames)
; mycall = DL1ABC-0
; dest = DL9XYZ-0
; via = RELAY-7,WIDE1-1
; host_connect = no

; Radio/modem side (TCM 3105 default = 1200; optional 9600/19200 on TNC2C-H)
modem = tcm3105
radio_baud = 1200
clock_mhz = 4.9

; KISS parameters (applied after "kiss on" when kiss_on_startup = yes)
kiss_port = 0
kiss_on_startup = yes
txdelay = 50
persist = 128
slot = 10
txtail = 0

; RF band and duplex (CB = half-duplex only; amateur may use full-duplex)
; radio_band = cb | amateur
; radio_duplex = half | full
; Legacy alias: fullduplex = yes | no  (maps to radio_duplex when unset)
radio_band = amateur
radio_duplex = half
fullduplex = no

; Over-the-air modulation (CB and amateur)
; g3ruh_fsk = yes enables G3RUH 9600 baud FSK (higher throughput; needs compatible modem)
; modulation = afsk | g3ruh  (alias for g3ruh_fsk)
g3ruh_fsk = no

; --- Albrecht PC-COM (CB, half-duplex only) ---
; tnc = pccom
; protocol = hostmode
; radio_band = cb
; radio_duplex = half
; baud = 2400
; mycall = DL1ABC-0
; dest = DL9XYZ-0
; host_connect = yes

; --- BayCom-class modem (CB, half-duplex) ---
; tnc = baycom
; protocol = kiss
; radio_band = cb
; radio_duplex = half
; baud = 2400
; radio_baud = 1200
; g3ruh_fsk = no

; --- CB with G3RUH 9600 FSK (experimental; requires G3RUH-capable TNC/modem) ---
; tnc = tnc2c
; radio_band = cb
; radio_duplex = half
; g3ruh_fsk = yes
; protocol = kiss
; modem = 9600
; radio_baud = 9600

; Classic RS232/COM port example:
; device_type = serial
; device = /dev/ttyS0        ; Linux/BSD
; device = COM1              ; Windows (MinGW)
; device = serial.device     ; AmigaOS
; baud = 9600
; radio_baud = 1200

; TNC2C-H with switchable 9600 baud modem:
; modem = 9600
; radio_baud = 9600
; clock_mhz = 9.8

; 10 MHz TNC2C with up to 38400 baud host link:
; clock_mhz = 10
; baud = 38400
