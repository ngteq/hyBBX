; HyBBX Main — v1.0.1. Full keys: docs/MANUAL.md
; Template: Main datacenter (telnet + HBX hub). RF on Secondary unless standalone.

[service]
name = hyBBX

[time]
; clock = 24h | 12h | am_pm
; seconds = no

[storage]
backend = flatfile
path = data

[auth]
auto_login = yes
guest_prefix = Guest

[crypto]
password_hash = tinysha256
aes_gcm = tinyaes
chacha = monocypher
x25519 = monocypher
random = system

[traffic]
baud = 2400
line_width = 80
pace_output = yes
ansi = no
input_echo = no

[texts]
path = text

[chat]
channels = 10
message_max = 72
channel1 = Channel1
channel2 = Channel2
channel3 = Channel3
channel4 = Channel4
channel5 = Channel5
channel6 = Channel6
channel7 = Channel7
channel8 = Channel8
channel9 = Channel9
channel10 = Channel10

[mail]
enabled = yes
max_messages = 50
subject_max = 72
body_max = 2048
recycle_days = 10
path = mail

[networks]
ax25 = no
ardop = no
crdop = no
ssh = yes
websocket = no
circuit = yes

[transport.telnet]
bind = 0.0.0.0
bind6 = ::
port = 2323
ipv4 = yes
ipv6 = yes

[transport.ssh]
enabled = yes
bind = 0.0.0.0
bind6 = ::
port = 3232
ipv4 = yes
ipv6 = yes
hostkey_dir = keys

[transport.websocket]
enabled = yes
bind = 127.0.0.1
bind6 = ::1
port = 591
path = /hybbx
cert_dir = keys
ipv4 = yes
ipv6 = yes

[circuit]
enabled = yes
bind = 127.0.0.1
bind6 = ::1
port = 7323
ipv4 = yes
ipv6 = yes
link_auth = yes
link_password = changeme
link_stale_days = 10
max_links = 8
balance = yes
balance_lag_sec = 5
balance_queue_pause = 4096
balance_queue_break = 16384
balance_queue_cancel = 65536

[broadcast]
enabled = yes
ax25 = yes
tcp = yes
ax25_mycall = HYBBX
ax25_dest = QST

[ax25]
frequency1 = 27.205
frequency1_label = local-A
frequency2 = 27.215

; Bridge registry — one section per remote Secondary (name must match Secondary INI):
[transport.packet_radio1]
link_id = secondary-1
link_password = changeme
link_role = link
frequency_mhz = 27.205

[transport.packet_radio2]
link_id = secondary-2
link_password = changeme2
link_role = link
frequency_mhz = 27.205

; Optional digital bridges (external modem on Secondary):
; [transport.ardop1]  — docs/ARDOP.md
; [transport.crdop1]  — docs/CRDOP.md
